{
    "layer": "top",
    "position": "top",
    "height": 32,
    "modules-left": ["niri/workspaces", "mpris"],
    "modules-right": ["privacy", "cpu", "memory", "temperature", "wireplumber", "backlight", "battery", "network", "clock"],
	"niri/workspaces": {
		"format": "{value}"
	},
	"niri/window": {
		"format": "{app_id}",
		"rewrite": {
			"(.*)Cine": "Cine",
			"(.*)obsidian": "Obsidian",
			"(.*)Lollypop": "Lollypop",
			"(.*)Tuba": "Tuba",
			"(.*)planify": "Planify",
			"(.*)Nocturne": "Nocturne",
			"(.*)Nautilus": "Nautilus",
			"(.*)Loupe": "Loupe",
			"(.*)firefox": "Firefox"
		}
	},
	"mpris": {
		"format": "{status_icon} {dynamic}",
		"format-paused": "{status_icon} {dynamic}",
		"player-icons": {
			"default": "έΨ╢",
			"mpv": "ΏθΟ╡"
		},
		"status-icons": {
			"playing": "ΎΑΒ  ",
			"paused": "έΠ╕"
		},
		"ignored-players": ["firefox"],
		"dynamic-len": 50,
		"dynamic-order": ["title", "artist"]
	},
    "clock": {
 		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a %d %b  %I:%M %p}",
		"timezone": "America/Bogota",
		"locale": "es_CO.UTF-8"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "≤░Ζ╢ ",
            "deactivated": "≤░╛ς "
        }
    },
	"cpu": {
        "format": "ΎΜδ  {usage:02}",
        "interval": 2
    },
    "memory": {
        "format": "ΎΔΚ  {used:0.2f}",
        "interval": 2
    },
    "temperature": {
        "thermal-zone": 0,
        "hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
		"interval": 2,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["ΎΜΚ"]
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ΎΗΖ "]
    },
    "battery": {
        "states": {
			"good": 75,
            "warning": 20,
            "critical": 10
        },
        "interval": 10,
        "format": "{icon} {capacity:02}% | {power:0.1f}W",
        "format-charging": "ΎΤΤ ",
        "format-icons": ["≤░Β║", "≤░Β╝", "≤░Β╛", "≤░ΓΑ", "≤░Β╣"],
		"tooltip-format": "{capacity:02}% {power:0.1f}W"
    },
	"network": {
        "format-wifi": "ΎΘτ  {essid} {signaldBm}",
        "format-ethernet": "έΘΝ  {ifname}: {ipaddr}",
        "format-disconnected": "έγι  Disconnected",
		// "on-click": "/sbin/networkmanager_dmenu",
        "interval": 5
    },
    "wireplumber": {
        "format": "{icon} {volume:02}%",
        "format-muted": "ΎΣο ",
        "format-icons": {
            "headphones": "ΎΑξ ",
            "default": ["ΎΑρ "]
        }
    },
    "pulseaudio": {
        "format": "vol: {volume}%",
        "format-bluetooth": "{volume}% ≤░ξ░ ",
        "format-muted": "Ό╗ρ ",
        "format-icons": {
            "headphones": "ΎΑξ ",
            "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ "]
        }
        // "on-click": "pavucontrol"
    },
	"privacy": {
		"icon-spacing": 2,
		"icon-size": 14,
		"modules": [
			{
				"type": "screenshare"
			},
			{
				"type": "audio-in"
			}
		]
	}
}
