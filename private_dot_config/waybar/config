{
    "layer": "top",
    "position": "top",
    "height": 32,
    "modules-left": ["niri/workspaces"],
	"modules-center": ["mpris"],
    "modules-right": ["privacy", "custom/run", "wireplumber", "battery", "clock"],
	"custom/run": {
