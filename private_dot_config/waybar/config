	"niri/window": {
		"format": "{app_id}",
		"rewrite": {
			"(.*)Cine": "Cine",
			"(.*)obsidian": "Obsidian",
			"(.*)Lollypop": "Lollypop",
			"(.*)Tuba": "Tuba",
			"(.*)planify": "Planify",
