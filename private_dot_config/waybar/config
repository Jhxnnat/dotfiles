{
    "layer": "top",
    "position": "bottom",
    "height": 32,
    "modules-left": ["mpris"],
    "modules-right": ["privacy", "wireplumber", "battery", "network", "clock"],

	"mpris": {
		"format": "{status_icon} {dynamic}",
		"format-paused": "{status_icon} {dynamic}",
		"player-icons": {
			"default": "▶",
			"mpv": "🎵"
		},
		"status-icons": {
			"paused": "⏸"
		},
		"ignored-players": ["firefox"],
		"dynamic-len": 50,
		"dynamic-order": ["title", "artist"]
	},
    "clock": {
 		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a %d %b, %I:%M %p}",
		"timezone": "America/Bogota",
		"locale": "es_CO.UTF-8"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 20
        },
        "interval": 10,
        "format": "bat: {capacity:02}%",
        "format-charging": "{capacity:02}",
        "format-icons": [" ", " ", " ", " ", " "],
		"tooltip-format": "{capacity:02}% {power:0.1f}W"
    },
    "network": {
		"tooltip-format": "{essid} {signaldBm}",
        "format-wifi": "<span size='12pt'> </span>",
        "format-ethernet": "<span size='12pt'>⇌ </span>",
        "format-disconnected": "<span size='12pt'>󰖪 </span>",
        "interval": 5
    },
    "wireplumber": {
        "format": "vol: {volume}%",
        "format-muted": "--",
        "format-bluetooth": "blt: {volume}",
        "format-icons": {
            "headphones": " ",
            "default": ["", " ", " "]
        }
        // "on-click": "helvum",
    },
    "pulseaudio": {
        "format": "vol: {volume}%",
        "format-bluetooth": "{volume}% 󰥰 ",
        "format-muted": " ",
        "format-icons": {
            "headphones": " ",
            "default": ["", " ", " "]
        }
        // "on-click": "pavucontrol"
    },
	"privacy": {
		"icon-spacing": 2,
		"icon-size": 14,
		"modules": [
			{
				"type": "screenshare"
			},
			{
				"type": "audio-in"
			}
		]
	},
	"backlight": {
		"format": "bl: {percent}%"
	},
	"custom/sep": {
		"format": "/"
	},
	"custom/search": {
		"format": " ",
		"on-click": "fuzzel"
	}
}
